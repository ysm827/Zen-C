
include <stdlib.h>
include <string.h>
include <stdio.h>
include <stdbool.h>
include <stdarg.h>

extern fn exit(code: int);

fn __zenc_panic_impl(file: const char*, line: int, func: const char*, msg: const char*) {
    fprintf(stderr, "%s:%d (%s): Panic: %s\n", file, line, func, msg);
    exit(1);
}

#define __zenc_panic(msg) __zenc_panic_impl(__FILE__, __LINE__, __func__, msg)